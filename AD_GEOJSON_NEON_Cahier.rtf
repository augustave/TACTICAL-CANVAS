\
\\<div class="dossier-wrapper"\\>  \
  \\<div class="tactical-canvas" id="map-container"\\>  \
    \\<div class="canvas-label"\\>Fig. 1 \'97 Tactical Legend & Filter\\</div\\>  \
    \\</div\\>\
\
  \\<div class="tab-container" id="legend-tabs"\\>  \
    \\<div class="legend-tab tab-infrastructure" data-target="infrastructure"\\>(1) BASE\\</div\\>  \
    \\<div class="legend-tab tab-pathway" data-target="pathway"\\>(2) PATH\\</div\\>  \
    \\<div class="legend-tab tab-organic" data-target="organic"\\>(3) ORGN\\</div\\>  \
    \\<div class="legend-tab tab-zone" data-target="zone"\\>(4) ZONE\\</div\\>  \
  \\</div\\>  \
\\</div\\>\
\
\\<script\\>  \
  // 1\\. Generate Simulated Payload  \
  const generateCluster \\= (baseType, baseX, baseY, count, spread) \\=\\> \{  \
    let cluster \\= \\[\\];  \
    for(let i \\= 0; i \\< count; i++) \{  \
      cluster.push(\{  \
        type: baseType,  \
        x: baseX \\+ (Math.random() \\* spread \\- (spread / 2)),  \
        y: baseY \\+ (Math.random() \\* spread \\- (spread / 2))  \
      \});  \
    \}  \
    return cluster;  \
  \};\
\
  const fullPayload \\= \\[  \
    ...generateCluster('infrastructure', 20, 20, 50, 15),  \
    ...generateCluster('infrastructure', 80, 80, 30, 10),  \
    ...generateCluster('pathway', 50, 50, 80, 40),  \
    ...generateCluster('organic', 40, 70, 150, 25), // Dense pink   \
    ...generateCluster('zone', 70, 30, 90, 20\\)      // Yellow zone  \
  \\];\
\
  // 2\\. Render Engine  \
  const container \\= document.getElementById('map-container');  \
  const renderedNodes \\= \\[\\]; // Store references for fast filtering\
\
  const renderScatterPlot \\= (data) \\=\\> \{  \
    const fragment \\= document.createDocumentFragment();\
\
    data.forEach(point \\=\\> \{  \
      const node \\= document.createElement('div');  \
      node.classList.add('data-node', \\`cat-$\{point.type\}\\`, 'size-md');  \
      // Store the category directly on the DOM element dataset for easy access  \
      node.dataset.category \\= point.type;   \
        \
      node.style.left \\= \\`$\{point.x\}%\\`;  \
      node.style.top \\= \\`$\{point.y\}%\\`;\
\
      fragment.appendChild(node);  \
      renderedNodes.push(node); // Keep track in memory  \
    \});\
\
    container.appendChild(fragment);  \
  \};\
\
  renderScatterPlot(fullPayload);\
\
  // 3\\. Tactical Legend Filter Logic  \
  const tabs \\= document.querySelectorAll('.legend-tab');  \
    \
  // State object tracking which layers are currently active  \
  const activeFilters \\= \{  \
    infrastructure: true,  \
    pathway: true,  \
    organic: true,  \
    zone: true  \
  \};\
\
  tabs.forEach(tab \\=\\> \{  \
    tab.addEventListener('click', () \\=\\> \{  \
      const targetCategory \\= tab.dataset.target;  \
        \
      // Toggle state  \
      activeFilters\\[targetCategory\\] \\= \\!activeFilters\\[targetCategory\\];  \
        \
      // Visually push/pull the physical tab  \
      if(activeFilters\\[targetCategory\\]) \{  \
        tab.classList.remove('is-disabled');  \
      \} else \{  \
        tab.classList.add('is-disabled');  \
      \}\
\
      // Update the Map Nodes  \
      renderedNodes.forEach(node \\=\\> \{  \
        if (node.dataset.category \\=== targetCategory) \{  \
          if (activeFilters\\[targetCategory\\]) \{  \
            node.classList.remove('is-hidden');  \
          \} else \{  \
            node.classList.add('is-hidden');  \
          \}  \
        \}  \
      \});  \
    \});  \
  \});\
\
\\</script\\>  \
\\</body\\>  \
\\</html\\>  \
