    flex-direction: column;  \
    gap: 6px;  \
    z-index: 5; /\\* Sit beneath the canvas \\*/  \
  \}\
\
  .legend-tab \{  \
    color: \\#151515;  \
    padding: 0.5rem 0.2rem;  \
    writing-mode: vertical-rl;  \
    text-orientation: mixed;  \
    border-radius: 0 6px 6px 0;  \
    font-size: 0.75rem;  \
    font-weight: 700;  \
    letter-spacing: 0.5px;  \
