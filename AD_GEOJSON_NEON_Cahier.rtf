module: "Data Visualization: NEON\\_SCATTER\\_PLOT"  \
version: "1.1-Expansion"  \
parent\\_guide: "THE\\_TACTICAL\\_DOSSIER"\
\
data\\_mapping\\_rules:  \
  ethos: "Density is Data. Do not use opacity to show heatmaps. Allow solid dots to overlap and occlude each other; the visual mass of a color indicates concentration."  \
    \
  node\\_anatomy:  \
    shape: "Perfect circle (border-radius: 50%)."  \
    scale: "Small to Micro (3px to 6px diameter). Scale remains fixed regardless of zoom level."  \
    effects: "ZERO effects. No drop shadows, no strokes, no gradients. Pure fill only."\
\
  category\\_color\\_mapping:  \
    \\# Colors derived from the tactical markers in the Amazonia reference.  \
    primary\\_infrastructure:   \
      color: "\\#151515" \\# Industrial Ink (Black)  \
      usage: "Base points, archaeological sites, foundational data."  \
    secondary\\_pathways:  \
      color: "\\#FF6600" \\# Flare Orange  \
      usage: "Geoglyphs, ditches, old roads, connections."  \
    organic\\_density:  \
      color: "\\#FF007F" \\# Marker Pink  \
      usage: "Brazil-nut trees, organic spread, high-volume localized data."  \
    environmental\\_zones:  \
      color: "\\#E5FF00" \\# Acid Yellow  \
      usage: "Dark earth, overarching zones, broad categorical boundaries."\
\
  rendering\\_logic:  \
    background\\_contrast: "The scatter plot must sit directly on a muted substrate (Terrain Grey \\#5D685C or Kraft Brown \\#A6927E). Do not place these neon dots on pure white or pure black."  \
    z\\_index\\_hierarchy: "Render sequence matters. Render black foundation points first (bottom), followed by orange, then pink, and finally yellow (top) to ensure critical highlights aren't buried."  \
