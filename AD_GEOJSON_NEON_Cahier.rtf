\\<body\\>\
\
\\<div class="tactical-canvas" id="map-container"\\>  \
  \\<div class="canvas-label"\\>Fig. 1 \'97 Tactical Scatter Plot\\</div\\>  \
  \\</div\\>\
\
\\<script\\>  \
  // 1\\. Simulated JSON Payload  \
  // Coordinates are represented as percentages (0-100) for responsive mapping.  \
  const intelligenceData \\= \\[  \
    \{ id: 1, type: "infrastructure", x: 15, y: 20 \},  \
    \{ id: 2, type: "infrastructure", x: 16, y: 22 \},  \
    \{ id: 3, type: "infrastructure", x: 80, y: 15 \},  \
    \{ id: 4, type: "pathway", x: 75, y: 40 \},  \
    \{ id: 5, type: "pathway", x: 77, y: 42 \},  \
    \{ id: 6, type: "organic", x: 40, y: 70 \},  \
    \{ id: 7, type: "organic", x: 42, y: 71 \},  \
    \{ id: 8, type: "organic", x: 41, y: 68 \},  \
    \{ id: 9, type: "organic", x: 43, y: 75 \},  \
    \{ id: 10, type: "zone", x: 60, y: 55 \},  \
    \{ id: 11, type: "zone", x: 61, y: 56 \},  \
    \{ id: 12, type: "zone", x: 63, y: 54 \}  \
  \\];\
\
  // Procedurally generate more data points to simulate the dense cluster effect  \
  const generateCluster \\= (baseType, baseX, baseY, count, spread) \\=\\> \{  \
    let cluster \\= \\[\\];  \
    for(let i \\= 0; i \\< count; i++) \{  \
      cluster.push(\{  \
        id: Math.random(),  \
        type: baseType,  \
        x: baseX \\+ (Math.random() \\* spread \\- (spread / 2)),  \
        y: baseY \\+ (Math.random() \\* spread \\- (spread / 2))  \
      \});  \
    \}  \
    return cluster;  \
  \};\
\
  // Build a dense payload  \
  const fullPayload \\= \\[  \
    ...intelligenceData,  \
    ...generateCluster('infrastructure', 20, 20, 50, 15),  \
    ...generateCluster('pathway', 75, 80, 40, 10),  \
    ...generateCluster('organic', 45, 60, 150, 25), // Dense pink cluster  \
    ...generateCluster('zone', 60, 50, 80, 20\\)      // Yellow zone  \
  \\];\
\
  // 2\\. The Rendering Engine  \
  const container \\= document.getElementById('map-container');\
\
  const renderScatterPlot \\= (data) \\=\\> \{  \
    // Document fragment for performance when appending hundreds of nodes  \
    const fragment \\= document.createDocumentFragment();\
\
    data.forEach(point \\=\\> \{  \
      const node \\= document.createElement('div');  \
        \
      // Assign core class  \
      node.classList.add('data-node');  \
        \
      // Map JSON 'type' to CSS Category Class  \
      node.classList.add(\\`cat-$\{point.type\}\\`);  \
        \
      // Determine size (Defaulting to md, but could be dynamic based on JSON weight)  \
      node.classList.add('size-md');\
\
      // Map JSON coordinates to absolute CSS positioning  \
      node.style.left \\= \\`$\{point.x\}%\\`;  \
      node.style.top \\= \\`$\{point.y\}%\\`;\
\
      fragment.appendChild(node);  \
    \});\
\
    container.appendChild(fragment);  \
  \};\
\
  // Execute  \
  renderScatterPlot(fullPayload);\
\
\\</script\\>  \
\\</body\\>  \
\\</html\\>  \
