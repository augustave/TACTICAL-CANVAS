    position: absolute;  \
    border-radius: 50%;  \
    transform: translate(-50%, \\-50%); /\\* Center on coordinate \\*/  \
  \}\
\
  /\\* Dynamic Size Classes \\*/  \
  .size-sm \{ width: 3px; height: 3px; \}  \
  .size-md \{ width: 5px; height: 5px; \}  \
  .size-lg \{ width: 7px; height: 7px; \}\
\
  /\\* Category Color Mapping \\*/  \
  .cat-infrastructure \{ background-color: \\#151515; z-index: 10; \} /\\* Black \\*/  \
  .cat-pathway        \{ background-color: \\#FF6600; z-index: 20; \} /\\* Orange \\*/  \
  .cat-organic        \{ background-color: \\#FF007F; z-index: 30; \} /\\* Pink \\*/  \
  .cat-zone           \{ background-color: \\#E5FF00; z-index: 40; \} /\\* Yellow \\*/\
