\
  /\\* Specific Tab Colors matching the Data \\*/  \
  .tab-infrastructure \{ background-color: \\#151515; color: \\#F0F0F0; border: 1px solid \\#333; \}  \
  .tab-pathway        \{ background-color: \\#FF6600; \}  \
  .tab-organic        \{ background-color: \\#FF007F; \}  \
  .tab-zone           \{ background-color: \\#E5FF00; \}\
\
  /\\* Hover and Active States \\*/  \
  .legend-tab:hover \{  \
